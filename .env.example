# URL de base du backend Drupal GoodRecipes (WAMP)
# Adapter selon votre virtual host Apache configuré dans WAMP
# Exemples :
#   http://localhost                     (si le site est à la racine de www/)
#   http://goodrecipes-back.local        (si virtual host configuré)
#   http://localhost/goodrecipes_back    (si accès via sous-dossier)
NUXT_PUBLIC_DRUPAL_BASE_URL=http://localhost
